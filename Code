# STEP 1: TEAM DATA FROM THE INTERNET

def fetch_team_info():
    """
    Fetch team info from football-data.org. Returns a dict mapping
    team name -> team info, or empty dict if the API fails.
    This is used for potential future enhancements — the core
    simulator uses hard-coded rankings.
    """
    url = f'{BASE_URL}/competitions/{COMPETITION_CODE}/teams'
    headers = {'X-Auth-Token': API_KEY}

    try:
        response = requests.get(url, headers=headers, timeout=10)
    except requests.exceptions.RequestException as e:
        print(f'Could not reach the API: {e}')
        return {}

    if response.status_code != 200:
        print(f'API returned an error (status {response.status_code})')
        return {}

    data = response.json()
    team_info = {}
    for team in data['teams']:
        team_info[team['name']] = team
    return team_info


# STEP 2: CONVERT FIFA RANKING TO TEAM RATING

def ranking_to_rating(rank):
    """
    Convert a FIFA ranking (1 = best) into a numeric rating.
    Top-ranked teams get ratings around 92-95, lower-ranked teams
    get ratings around 65-75.

    We use a simple linear scale: rank 1 -> 95, and the rating
    decreases as the rank number increases.
    """
    if rank <= 5:
        return 95 - (rank - 1) * 1
    elif rank <= 15:
        return 90 - (rank - 5) * 0.8
    elif rank <= 30:
        return 82 - (rank - 15) * 0.6
    elif rank <= 60:
        return 73 - (rank - 30) * 0.3
    else:
        return max(60, 64 - (rank - 60) * 0.15)


def build_team(team_name):
    """
    Build a team dictionary using the team's real FIFA ranking.
    Offense and defense are derived from the base rating with small
    random variation (some teams are more attack-minded, some more
    defense-minded).
    """
    # Look up the team's FIFA ranking (default to 80 if missing)
    rank = FIFA_RANKINGS.get(team_name, 80)
    base_rating = ranking_to_rating(rank)

    # Split base rating into offense and defense with small variation
    offense_variation = random.uniform(-3, 3)
    defense_variation = random.uniform(-3, 3)

    offense = round(base_rating + offense_variation, 1)
    defense = round(base_rating + defense_variation, 1)

    return {
        'name': team_name,
        'fifa_rank': rank,
        'offense': offense,
        'defense': defense,
        'star_player_out': random.random() < 0.15,   # ~15% of teams
        'points': 0,
        'goals_for': 0,
        'goals_against': 0,
        'group': None,
    }


# STEP 3: CALCULATE EFFECTIVE MATCH RATING

def calculate_rating(team):
    """
    Compute a team's effective rating for a match.
    Combines offense and defense, then applies host and injury modifiers.
    """
    rating = (team['offense'] + team['defense']) / 2

    # Host nations get home-field advantage
    if team['name'] in HOST_NATIONS:
        rating = rating * HOME_ADVANTAGE

    # Penalty if star player is out
    if team['star_player_out']:
        rating = rating * INJURY_PENALTY

    return rating


# STEP 4: SIMULATE A SINGLE MATCH

def simulate_match(team_a, team_b, allow_draw):
    """
    Simulate one match. Returns (result, score_a, score_b) where
    result is 'A', 'B', or 'DRAW'.

    We raise the ratings to a power > 1 before computing probability.
    This amplifies the gap between strong and weak teams so upsets
    are possible but the stronger team usually wins.
    """
    rating_a = calculate_rating(team_a)
    rating_b = calculate_rating(team_b)

    # Exponent > 1 means stronger teams are more favored than a linear
    # ratio would suggest. A value of 4 gives reasonable soccer-like
    # outcomes where a 90-rated team beats a 75-rated team ~80% of
    # the time, but upsets still happen.
    power = 4
    weighted_a = rating_a ** power
    weighted_b = rating_b ** power
    prob_a = weighted_a / (weighted_a + weighted_b)

    # Generate realistic scores
    score_a = generate_score(prob_a)
    score_b = generate_score(1 - prob_a)

    if score_a > score_b:
        result = 'A'
    elif score_b > score_a:
        result = 'B'
    else:
        # Tied
        if allow_draw:
            result = 'DRAW'
        else:
            # Knockout — simulate penalty shootout weighted by rating
            if random.random() < prob_a:
                result = 'A'
                score_a += 1
            else:
                result = 'B'
                score_b += 1

    return result, score_a, score_b


def generate_score(win_probability):
    """
    Generate a realistic soccer score (0-4 goals).
    Higher win probability means more goals on average.
    """
    if win_probability > 0.7:
        return random.choices([0, 1, 2, 3, 4], weights=[5, 20, 30, 30, 15])[0]
    elif win_probability > 0.55:
        return random.choices([0, 1, 2, 3, 4], weights=[10, 25, 30, 25, 10])[0]
    elif win_probability > 0.4:
        return random.choices([0, 1, 2, 3, 4], weights=[20, 35, 25, 15, 5])[0]
    else:
        return random.choices([0, 1, 2, 3, 4], weights=[35, 35, 20, 8, 2])[0]


# STEP 5: BUILD GROUPS FROM THE REAL DRAW

def build_tournament_groups():
    """Build the tournament groups using the real 2026 World Cup draw."""
    groups = {}
    for group_letter, team_names in WORLD_CUP_2026_GROUPS.items():
        group_teams = []
        for name in team_names:
            team = build_team(name)
            team['group'] = group_letter
            group_teams.append(team)
        groups[group_letter] = group_teams
    return groups


# STEP 6: GROUP STAGE

def play_group_match(team_a, team_b):
    """Play one group match and update both teams' stats."""
    result, score_a, score_b = simulate_match(team_a, team_b, allow_draw=True)

    team_a['goals_for'] += score_a
    team_a['goals_against'] += score_b
    team_b['goals_for'] += score_b
    team_b['goals_against'] += score_a

    if result == 'A':
        team_a['points'] += 3
    elif result == 'B':
        team_b['points'] += 3
    else:
        team_a['points'] += 1
        team_b['points'] += 1


def play_group_stage(groups):
    """
    Play all group-stage matches (round-robin within each group).
    Returns (group_winners, runners_up, third_place).
    """
    group_winners = []
    runners_up = []
    third_place = []

    for group_letter, group in groups.items():
        print(f'\n--- GROUP {group_letter} ---')

        for i in range(len(group)):
            for j in range(i + 1, len(group)):
                play_group_match(group[i], group[j])

        # Sort by points, then goal difference, then goals scored
        group.sort(
            key=lambda t: (
                t['points'],
                t['goals_for'] - t['goals_against'],
                t['goals_for'],
            ),
            reverse=True,
        )

        # Print standings
        print(f"{'Team':<22}{'Rank':<6}{'Pts':<5}{'GF':<5}{'GA':<5}{'GD':<5}")
        for team in group:
            gd = team['goals_for'] - team['goals_against']
            print(f"{team['name']:<22}#{team['fifa_rank']:<5}"
                  f"{team['points']:<5}{team['goals_for']:<5}"
                  f"{team['goals_against']:<5}{gd:<5}")

        group_winners.append(group[0])
        runners_up.append(group[1])
        third_place.append(group[2])

    return group_winners, runners_up, third_place


def select_best_third_place_teams(third_place_teams):
    """
    Pick the 8 best third-place teams, ranked by points, goal
    difference, then goals scored (real FIFA tiebreaker rules).
    """
    ranked = sorted(
        third_place_teams,
        key=lambda t: (
            t['points'],
            t['goals_for'] - t['goals_against'],
            t['goals_for'],
        ),
        reverse=True,
    )
    return ranked[:BEST_THIRDS_ADVANCING]


# STEP 7: KNOCKOUT STAGE

def play_knockout_round(teams, round_name):
    """Play one knockout round. Returns list of winners."""
    print(f'\n========== {round_name} ==========')
    winners = []

    for i in range(0, len(teams), 2):
        team_a = teams[i]
        team_b = teams[i + 1]

        result, score_a, score_b = simulate_match(
            team_a, team_b, allow_draw=False
        )

        if result == 'A':
            winner = team_a
        else:
            winner = team_b

        print(f"{team_a['name']} (#{team_a['fifa_rank']}) {score_a} - "
              f"{score_b} {team_b['name']} (#{team_b['fifa_rank']})"
              f"   -->  {winner['name']} advances")
        winners.append(winner)

    return winners


# STEP 8: MAIN TOURNAMENT


def run_tournament():
    """Run the entire 2026 World Cup simulation from start to finish."""
    print('=' * 60)
