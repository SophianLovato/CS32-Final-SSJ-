    else:
        print('Proceeding with built-in FIFA rankings.')

    # Build groups using the real draw + real rankings
    groups = build_tournament_groups()

    # GROUP STAGE
    print('\n' + '=' * 60)
    print('                  GROUP STAGE')
    print('=' * 60)
    winners, runners_up, thirds = play_group_stage(groups)

    best_thirds = select_best_third_place_teams(thirds)
    print('\n--- 8 BEST THIRD-PLACE TEAMS ADVANCING ---')
    for team in best_thirds:
        gd = team['goals_for'] - team['goals_against']
        print(f"  {team['name']} (Group {team['group']}, "
              f"FIFA #{team['fifa_rank']}) - "
              f"{team['points']} pts, GD {gd:+d}")

    # Round of 32
    round_of_32 = winners + runners_up + best_thirds
    random.shuffle(round_of_32)   # Simplified bracket pairing

    # KNOCKOUT STAGE
    print('\n' + '=' * 60)
    print('                 KNOCKOUT STAGE')
    print('=' * 60)
    round_of_16 = play_knockout_round(round_of_32, 'ROUND OF 32')
    quarterfinalists = play_knockout_round(round_of_16, 'ROUND OF 16')
    semifinalists = play_knockout_round(quarterfinalists, 'QUARTERFINALS')
    finalists = play_knockout_round(semifinalists, 'SEMIFINALS')
    champion_list = play_knockout_round(finalists, 'FINAL')

    # CHAMPION
    champion = champion_list[0]
    print('\n' + '=' * 60)
    print(f'     2026 WORLD CUP CHAMPION: {champion["name"]}!')
    print('=' * 60)
    print(f"FIFA Ranking: #{champion['fifa_rank']}")
    print(f"Group: {champion['group']}")
    print(f"Offense: {champion['offense']}, Defense: {champion['defense']}")
    if champion['name'] in HOST_NATIONS:
        print('(Won on home soil!)')
    if champion['star_player_out']:
        print('(Won despite missing a star player!)')


if __name__ == '__main__':
    run_tournament()
